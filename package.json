{
  "name": "@dalin/tactile",
  "version": "0.1.0",
  "description": "Make web interactions feel real. One call fires coordinated haptics, sound, and motion — each independently tunable and toggleable. Pure-web today; swappable to a native haptic backend later.",
  "type": "module",
  "license": "MIT",
  "author": "Samuel Gomez",
  "repository": { "type": "git", "url": "git+https://github.com/gomezsj12/dalin-tactile.git" },
  "homepage": "https://github.com/gomezsj12/dalin-tactile#readme",
  "bugs": { "url": "https://github.com/gomezsj12/dalin-tactile/issues" },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sound": {
      "types": "./dist/sound/index.d.ts",
      "import": "./dist/sound/index.js"
    },
    "./motion": {
      "types": "./dist/motion/index.d.ts",
      "import": "./dist/motion/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\" \"*.{json,md}\" \"docs/**/*.md\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "size": "node scripts/check-size.mjs",
    "demo": "npm run build && node demo/server.mjs"
  },
  "keywords": [
    "haptics",
    "vibration",
    "taptic",
    "sound",
    "web-audio",
    "motion",
    "microinteraction",
    "confetti",
    "particles",
    "boop",
    "pwa",
    "feedback"
  ],
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.11.0",
    "vitest": "^2.1.0"
  }
}
